Route::post('/generate-controlnet', function (Request $request) {
    $startTime = microtime(true);
    
    try {
        $model = $request->input('model', 'dreamshaper_8.safetensors');
        $controlNetData = $request->input('controlnet', []);
        $controlNetEnabled = $controlNetData['enabled'] ?? false;
        
        // Available ControlNet models from your files
        $availableControlNetModels = [
            'canny' => 'control_sd15_canny.pth',
            'depth' => 'control_sd15_depth.pth',
            'openpose' => 'control_sd15_openpose.pth',
            'scribble' => 'control_sd15_scribble.pth',
            'mlsd' => 'control_sd15_mlsd.pth',
            'hed' => 'control_sd15_hed.pth',
            'seg' => 'control_sd15_seg.pth',
            'normal' => 'control_sd15_normal.pth'
        ];
        
        // Force using SD1.5 compatible models for ControlNet (since all ControlNets are SD1.5)
        $sd15Models = [
            'dreamshaper_8.safetensors',
            'v1-5-pruned-emaonly-fp16.safetensors',
            'v1-5-pruned.safetensors',
            'realisticVisionV60B1_v51HyperVAE.safetensors',
            'interior_design_sd15.safetensors',
            'architecture_interior_v1.safetensors'
        ];
        
        if ($controlNetEnabled && !in_array($model, $sd15Models)) {
            \Log::warning('ControlNet requires SD1.5 model, overriding', ['original' => $model]);
            $model = 'dreamshaper_8.safetensors'; // fallback to a reliable SD1.5 model
        }
        
        if ($controlNetEnabled && !empty($controlNetData['image_base64'])) {
            $preprocessor = $controlNetData['preprocessor'] ?? 'canny';
            
            // Verify the ControlNet model exists (optional, you could check file existence)
            $controlNetModel = $availableControlNetModels[$preprocessor] ?? 'control_sd15_canny.pth';
            
            \Log::info('Using ControlNet model', [
                'preprocessor' => $preprocessor,
                'model_file' => $controlNetModel
            ]);
            
            $workflow = buildControlNetWorkflow(
                $model,
                $request->input('positive_prompt', 'masterpiece, best quality, beautiful landscape'),
                $request->input('negative_prompt', 'worst quality, low quality, blurry'),
                $request->input('steps', 20),
                $request->input('cfg', 7.0),
                $request->input('width', 768),
                $request->input('height', 768),
                $request->input('sampler', 'dpmpp_2m'),
                $preprocessor,
                $controlNetData['image_base64'],
                $controlNetData['strength'] ?? 0.85,
                $controlNetData['start_percent'] ?? 0.0,
                $controlNetData['end_percent'] ?? 1.0
            );
        } else {
            $workflow = buildBaseWorkflow(
                $model,
                $request->input('positive_prompt', 'masterpiece, best quality, beautiful landscape'),
                $request->input('negative_prompt', 'worst quality, low quality, blurry'),
                $request->input('steps', 20),
                $request->input('cfg', 7.0),
                $request->input('width', 768),
                $request->input('height', 768),
                $request->input('sampler', 'dpmpp_2m')
            );
        }
        
        $response = Http::timeout(180)->post('http://127.0.0.1:8188/prompt', [
            'prompt' => $workflow,
            'client_id' => $request->input('client_id', 'laravel-client')
        ]);
        
        $endTime = microtime(true);
        $duration = round($endTime - $startTime, 2);
        
        if ($response->successful()) {
            \Log::info('Generation successful', [
                'duration_seconds' => $duration,
                'model' => $model,
                'controlnet_enabled' => $controlNetEnabled
            ]);
            
            return response()->json([
                'success' => true, 
                'prompt_id' => $response->json()['prompt_id'],
                'duration' => $duration
            ]);
        }
        
        $errorResponse = $response->json();
        \Log::error('ComfyUI error', ['error' => $errorResponse]);
        
        return response()->json([
            'success' => false, 
            'error' => $errorResponse
        ], 500);
        
    } catch (\Exception $e) {
        \Log::error('Generation failed', [
            'error' => $e->getMessage(),
            'trace' => $e->getTraceAsString()
        ]);
        
        return response()->json([
            'success' => false, 
            'error' => $e->getMessage()
        ], 500);
    }
});

// Single endpoint for available preprocessors
Route::get('/available-preprocessors', function () {
    try {
        $available = [];
        
        // Define all possible preprocessors with their node names
        $allPreprocessors = [
            'canny' => 'Canny',
            'depth' => 'DepthAnythingPreprocessor',
            'openpose' => 'OpenposePreprocessor',
            'scribble' => 'ScribblePreprocessor',
            'mlsd' => 'MLSD-Lines_Preprocessor',
            'hed' => 'HEDPreprocessor',
            'seg' => 'SegformerPreprocessor',
            'normal' => 'NormalMapPreprocessor'
        ];
        
        // Check if comfyui_controlnet_aux is installed
        $controlNetAuxPath = env('COMFYUI_CONTROLNET_AUX_PATH', '/home/batkhuu/ComfyUI/custom_nodes/comfyui_controlnet_aux');
        
        if (file_exists($controlNetAuxPath)) {
            // If controlnet_aux is installed, assume all preprocessors are available
            // but we'll still check for specific ones
            $available = array_keys($allPreprocessors);
            
            // Check specifically for MLSD by looking at nodes.py content
            $nodesFile = $controlNetAuxPath . '/nodes.py';
            if (file_exists($nodesFile)) {
                $content = file_get_contents($nodesFile);
                if (strpos($content, 'MLSD-Lines_Preprocessor') === false) {
                    // Remove MLSD if not found
                    $available = array_filter($available, function($item) {
                        return $item !== 'mlsd';
                    });
                }
            }
        } else {
            // Fallback to basic Canny only if controlnet_aux is not installed
            $available = ['canny'];
        }
        
        // Ensure at least canny is available
        if (empty($available)) {
            $available = ['canny'];
        }
        
        return response()->json([
            'available_preprocessors' => $available,
            'all_preprocessors' => array_keys($allPreprocessors),
            'comfyui_path' => env('COMFYUI_PATH', '/home/batkhuu/ComfyUI'),
            'controlnet_aux_installed' => file_exists($controlNetAuxPath)
        ]);
    } catch (\Exception $e) {
        \Log::error('Available preprocessors error: ' . $e->getMessage());
        return response()->json([
            'error' => $e->getMessage(),
            'available_preprocessors' => ['canny'] // Default fallback
        ], 500);
    }
});

