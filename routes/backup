// Add endpoint to get recent images
Route::get('/recent-images', function () {
    try {
        $outputPath = env('COMFYUI_OUTPUT_DIR', '/home/batkhuu/ComfyUI/output');
        $images = [];
        
        if (file_exists($outputPath)) {
            $files = glob($outputPath . '/*.png');
            usort($files, function($a, $b) {
                return filemtime($b) - filemtime($a);
            });
            
            foreach (array_slice($files, 0, 20) as $file) {
                $images[] = [
                    'filename' => basename($file),
                    'path' => $file,
                    'timestamp' => filemtime($file),
                    'size' => filesize($file)
                ];
            }
        }
        
        return response()->json(['images' => $images]);
    } catch (\Exception $e) {
        return response()->json(['error' => $e->getMessage()], 500);
    }
});

Route::get('/debug-permissions', function () {
    $paths = [
        env('COMFYUI_INPUT_DIR', '/home/batkhuu/ComfyUI/input'),
        storage_path('app/comfyui/input'),
        public_path('comfyui_input'),
        sys_get_temp_dir() . '/comfyui_input',
        '/tmp/comfyui_input'
    ];
    
    $results = [];
    
    foreach ($paths as $path) {
        $exists = file_exists($path);
        $isWritable = false;
        $canCreate = false;
        
        if ($exists) {
            $isWritable = is_writable($path);
            $results[] = [
                'path' => $path,
                'exists' => true,
                'writable' => $isWritable,
                'permissions' => substr(sprintf('%o', fileperms($path)), -4),
                'owner' => function_exists('posix_getpwuid') ? posix_getpwuid(fileowner($path))['name'] ?? 'unknown' : 'unknown'
            ];
        } else {
            // Try to create it
            $canCreate = @mkdir($path, 0777, true);
            $results[] = [
                'path' => $path,
                'exists' => false,
                'can_create' => $canCreate,
                'writable_after_create' => $canCreate ? is_writable($path) : false
            ];
        }
    }
    
    // Also check PHP's temp directory
    $results[] = [
        'path' => 'php_temp_dir',
        'value' => sys_get_temp_dir(),
        'writable' => is_writable(sys_get_temp_dir())
    ];
    
    return response()->json($results);
});

