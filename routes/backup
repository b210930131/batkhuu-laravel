if (!function_exists('saveImageToComfyUI')) {
    function saveImageToComfyUI($base64Image, $filename) {
        // First, try the user's ComfyUI input directory (adjust path if needed)
        $comfyInputDir = env('COMFYUI_INPUT_DIR', '/home/batkhuu/ComfyUI/input');
        
        // Fallback paths
        $possiblePaths = [
            $comfyInputDir,
            storage_path('app/comfyui/input'),
            public_path('comfyui_input'),
            sys_get_temp_dir() . '/comfyui_input',
            '/tmp/comfyui_input'
        ];
        
        $lastError = null;
        $successPath = null;
        
        foreach ($possiblePaths as $path) {
            try {
                // Create directory if it doesn't exist
                if (!file_exists($path)) {
                    if (!@mkdir($path, 0777, true)) {
                        continue;
                    }
                }
                
                // Check if directory is writable
                if (!is_writable($path)) {
                    \Log::warning("Directory not writable: " . $path);
                    continue;
                }
                
                $fullPath = $path . '/' . $filename;
                
                // Clean base64 data (remove data URL prefix)
                $cleanBase64 = $base64Image;
                if (strpos($cleanBase64, 'base64,') !== false) {
                    $cleanBase64 = explode('base64,', $cleanBase64)[1];
                }
                
                // Clean up any whitespace
                $cleanBase64 = preg_replace('/\s+/', '', $cleanBase64);
                
                // Decode base64
                $imageData = base64_decode($cleanBase64);
                
                if ($imageData === false) {
                    throw new \Exception('Failed to decode base64 image');
                }
                
                // Save the file
                if (file_put_contents($fullPath, $imageData) !== false) {
                    $successPath = $fullPath;
                    \Log::info("Image saved successfully", ['path' => $fullPath]);
                    break;
                } else {
                    throw new \Exception('Failed to write file');
                }
                
            } catch (\Exception $e) {
                $lastError = $e;
                \Log::warning("Failed to save to {$path}: " . $e->getMessage());
                continue;
            }
        }
        
        if (!$successPath) {
            throw new \Exception('Failed to save image to any location. Last error: ' . ($lastError ? $lastError->getMessage() : 'Unknown'));
        }
        
        // If we saved to a non-ComfyUI directory, try to copy it to the main ComfyUI input directory
        if (strpos($successPath, $comfyInputDir) !== 0) {
            $comfyPath = $comfyInputDir . '/' . $filename;
            if (is_writable(dirname($comfyPath))) {
                if (!copy($successPath, $comfyPath)) {
                    \Log::warning("Could not copy to ComfyUI input", ['from' => $successPath, 'to' => $comfyPath]);
                } else {
                    \Log::info("Copied to ComfyUI input", ['path' => $comfyPath]);
                    return $filename;
                }
            }
        }
        
        return $filename;
    }
}

if (!function_exists('buildControlNetWorkflow')) {
    function buildControlNetWorkflow($model, $positivePrompt, $negativePrompt, $steps, $cfg, $width, $height, $sampler, $preprocessor, $controlImageBase64, $strength, $startPercent, $endPercent) {
        
        // Save control image
        $tempFileName = 'control_image_' . uniqid() . '.png';
        $savedFileName = saveImageToComfyUI($controlImageBase64, $tempFileName);
        
        $workflow = [
            "4" => [
                "class_type" => "CheckpointLoaderSimple",
                "inputs" => ["ckpt_name" => $model]
            ],
            
            "10" => [
                "class_type" => "LoadImage",
                "inputs" => [
                    "image" => $savedFileName
                ]
            ],
        ];
        
        // Map preprocessors to their node types and inputs
        $preprocessorConfigs = [
            'canny' => [
                'class_type' => 'CannyEdgePreprocessor',
                'inputs' => [
                    'image' => ["10", 0],
                    'low_threshold' => 0.1,
                    'high_threshold' => 0.2
                ]
            ],
            'depth' => [
                'class_type' => 'DepthAnythingV2Preprocessor',
                'inputs' => ['image' => ["10", 0]]
            ],
            'openpose' => [
                'class_type' => 'OpenposePreprocessor',
                'inputs' => [
                    'image' => ["10", 0],
                    'detect_hand' => "enable",
                    'detect_body' => "enable"
                ]
            ],
            'scribble' => [
                'class_type' => 'ScribblePreprocessor',
                'inputs' => ['image' => ["10", 0]]
            ],
            'mlsd' => [
                'class_type' => 'MLSDPreprocessor', 
                'inputs' => [
                'image' => ["10", 0],
                'thr_v' => 0.1,  // 'threshold' биш 'thr_v' (score threshold)
                'thr_d' => 0.1,  // 'thr_d' (distance threshold)
                'resolution' => 512
    ]
            ],
            'hed' => [
                'class_type' => 'HEDPreprocessor',
                'inputs' => [
                    'image' => ["10", 0],
                    'resolution' => 512
                ]
            ],
            'seg' => [
                'class_type' => 'SegformerPreprocessor',
                'inputs' => ['image' => ["10", 0]]
            ],
            'normal' => [
                'class_type' => 'NormalMapPreprocessor',
                'inputs' => ['image' => ["10", 0]]
            ]
        ];
        
        // Use selected preprocessor or fallback to canny
        $selectedConfig = $preprocessorConfigs[$preprocessor] ?? $preprocessorConfigs['canny'];
        $workflow["11"] = $selectedConfig;
        
        // ControlNet models mapping (SD1.5 models)
        $controlNetModels = [
            'canny' => 'control_sd15_canny.pth',
            'depth' => 'control_sd15_depth.pth',
            'openpose' => 'control_sd15_openpose.pth',
            'scribble' => 'control_sd15_scribble.pth',
            'mlsd' => 'control_sd15_mlsd.pth',
            'hed' => 'control_sd15_hed.pth',
            'seg' => 'control_sd15_seg.pth',
            'normal' => 'control_sd15_normal.pth'
        ];
        
        $workflow["12"] = [
            "class_type" => "ControlNetLoader",
            "inputs" => [
                "control_net_name" => $controlNetModels[$preprocessor] ?? 'control_sd15_canny.pth'
            ]
        ];
        
        // Apply ControlNet
        $workflow["13"] = [
            "class_type" => "ControlNetApplyAdvanced",
            "inputs" => [
                "positive" => ["6", 0],
                "negative" => ["7", 0],
                "control_net" => ["12", 0],
                "image" => ["11", 0],
                "strength" => $strength,
                "start_percent" => $startPercent,
                "end_percent" => $endPercent
            ]
        ];
        
        $workflow["5"] = [
            "class_type" => "EmptyLatentImage",
            "inputs" => [
                "width" => $width,
                "height" => $height,
                "batch_size" => 1
            ]
        ];
        
        $workflow["6"] = [
            "class_type" => "CLIPTextEncode",
            "inputs" => [
                "text" => $positivePrompt,
                "clip" => ["4", 1]
            ]
        ];
        
        $workflow["7"] = [
            "class_type" => "CLIPTextEncode",
            "inputs" => [
                "text" => $negativePrompt,
                "clip" => ["4", 1]
            ]
        ];
        
        $workflow["3"] = [
            "class_type" => "KSampler",
            "inputs" => [
                "seed" => rand(1, 999999999),
                "steps" => $steps,
                "cfg" => $cfg,
                "sampler_name" => $sampler,
                "scheduler" => "normal",
                "denoise" => 1,
                "model" => ["4", 0],
                "positive" => ["13", 0],
                "negative" => ["13", 1],
                "latent_image" => ["5", 0]
            ]
        ];
        
        $workflow["8"] = [
            "class_type" => "VAEDecode",
            "inputs" => [
                "samples" => ["3", 0],
                "vae" => ["4", 2]
            ]
        ];
        
        $workflow["9"] = [
            "class_type" => "SaveImage",
            "inputs" => [
                "filename_prefix" => "controlnet_" . $preprocessor,
                "images" => ["8", 0]
            ]
        ];
        
        return $workflow;
    }
}

