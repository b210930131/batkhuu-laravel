    public function generate(Request $request)
    {
        try {
            Log::info('Generate request received', ['request_data' => $request->all()]);
            
            // Validate input with all ControlNet parameters
            $validated = $request->validate([
                'model'                     => 'required|string',
                'positive_prompt'           => 'required|string',
                'negative_prompt'           => 'nullable|string',
                'steps'                     => 'integer|min:1|max:100',
                'cfg'                       => 'numeric|min:1|max:20',
                'width'                     => 'integer|min:256|max:1536',
                'height'                    => 'integer|min:256|max:1536',
                'sampler'                   => 'string',
                'controlnet'                => 'nullable|array',
                'controlnet.enabled'        => 'boolean',
                'controlnet.preprocessor'   => 'string',
                'controlnet.image_base64'   => 'nullable|string',
                'controlnet.strength'       => 'numeric|min:0|max:2',
                'controlnet.start_percent'  => 'numeric|min:0|max:1',
                'controlnet.end_percent'    => 'numeric|min:0|max:1',
                
                // Canny thresholds
                'controlnet.canny_low_threshold' => 'nullable|numeric|min:0|max:255',
                'controlnet.canny_high_threshold' => 'nullable|numeric|min:0|max:255',
                
                // Other preprocessor settings
                'controlnet.depth_resolution' => 'nullable|integer|min:256|max:1024',
                'controlnet.openpose_hands' => 'nullable|string|in:enable,disable',
                'controlnet.openpose_body' => 'nullable|string|in:enable,disable',
                'controlnet.openpose_face' => 'nullable|string|in:enable,disable',
                'controlnet.mlsd_score_threshold' => 'nullable|numeric|min:0|max:1',
                'controlnet.mlsd_distance_threshold' => 'nullable|numeric|min:0|max:1',
                'controlnet.mlsd_resolution' => 'nullable|integer|min:256|max:1024',
                'controlnet.hed_resolution' => 'nullable|integer|min:256|max:1024',
                'controlnet.scribble_mode' => 'nullable|string|in:simple,edge',
                'controlnet.seg_resolution' => 'nullable|integer|min:256|max:1024',
                'controlnet.normal_resolution' => 'nullable|integer|min:256|max:1024',
            ]);

            // Handle Canny thresholds
            if (!empty($validated['controlnet']['enabled']) && 
                isset($validated['controlnet']['preprocessor']) &&
                $validated['controlnet']['preprocessor'] === 'canny') {
                
                $rawLow = isset($validated['controlnet']['canny_low_threshold']) 
                    ? (float)$validated['controlnet']['canny_low_threshold'] 
                    : 50;
                $rawHigh = isset($validated['controlnet']['canny_high_threshold']) 
                    ? (float)$validated['controlnet']['canny_high_threshold'] 
                    : 150;
                
                // If values are normalized (0-1), convert to 0-255
                if ($rawLow <= 1 && $rawHigh <= 1) {
                    $rawLow = $rawLow * 255;
                    $rawHigh = $rawHigh * 255;
                }
                
                $rawLow = (int)round($rawLow);
                $rawHigh = (int)round($rawHigh);
                $rawLow = max(0, min(255, $rawLow));
                $rawHigh = max(0, min(255, $rawHigh));
                
                $validated['controlnet']['canny_raw_low'] = $rawLow;
                $validated['controlnet']['canny_raw_high'] = $rawHigh;
                $validated['controlnet']['canny_low_normalized'] = round($rawLow / 255, 3);
                $validated['controlnet']['canny_high_normalized'] = round($rawHigh / 255, 3);
                $validated['controlnet']['canny_low_normalized'] = max(0, min(0.99, $validated['controlnet']['canny_low_normalized']));
                $validated['controlnet']['canny_high_normalized'] = max(0, min(0.99, $validated['controlnet']['canny_high_normalized']));
                
                Log::info('Canny thresholds processed', [
                    'raw' => ['low' => $rawLow, 'high' => $rawHigh],
                    'normalized' => [
                        'low' => $validated['controlnet']['canny_low_normalized'],
                        'high' => $validated['controlnet']['canny_high_normalized']
                    ]
                ]);
            }

            // Build workflow
            if (!empty($validated['controlnet']['enabled']) && 
                !empty($validated['controlnet']['image_base64'])) {
                $workflow = $this->buildControlNetWorkflow($validated);
            } else {
                $workflow = $this->buildBaseWorkflow($validated);
            }

            // Send to ComfyUI
            $response = Http::timeout(180)->post($this->comfyUrl . '/prompt', [
                'prompt' => $workflow,
                'client_id' => $request->input('client_id', 'laravel-client'),
            ]);

            if ($response->failed()) {
                $errorBody = $response->body();
                Log::error('ComfyUI error', ['body' => $errorBody]);
                return response()->json(['error' => 'ComfyUI error: ' . $errorBody], 500);
            }

            $data = $response->json();

            return response()->json([
                'success' => true,
                'prompt_id' => $data['prompt_id']
            ]);
            
        } catch (\Illuminate\Validation\ValidationException $e) {
            Log::error('Validation failed', ['errors' => $e->errors()]);
            return response()->json([
                'error' => 'Validation failed',
                'errors' => $e->errors()
            ], 422);
            
        } catch (\Exception $e) {
            Log::error('Generation failed', ['error' => $e->getMessage()]);
            return response()->json(['error' => $e->getMessage()], 500);
        }
    }
    
