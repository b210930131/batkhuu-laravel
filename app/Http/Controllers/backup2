    protected function buildControlNetWorkflow(array $params)
{
    Log::info('=== CONTROLNET WORKFLOW BUILD ===', [
        'preprocessor' => $params['controlnet']['preprocessor'] ?? 'canny',
        'strength' => $params['controlnet']['strength'] ?? 0.85,
        'has_image' => !empty($params['controlnet']['image_base64'])
    ]);
    
    // Save control image
    $controlImage = $params['controlnet']['image_base64'];
    $strength = $params['controlnet']['strength'] ?? 0.85;
    $startPercent = $params['controlnet']['start_percent'] ?? 0.0;
    $endPercent = $params['controlnet']['end_percent'] ?? 1.0;
    $preprocessor = $params['controlnet']['preprocessor'] ?? 'canny';
    
    // Clean and save image
    if (strpos($controlImage, 'base64,') !== false) {
        $controlImage = explode('base64,', $controlImage)[1];
    }
    
    $controlImage = preg_replace('/\s+/', '', $controlImage);
    $imageData = base64_decode($controlImage);
    
    if ($imageData === false) {
        throw new \Exception('Failed to decode base64 image');
    }
    
    $filename = 'control_' . uniqid() . '.png';
    
    // Try multiple possible input directories
    $inputDirs = [
        env('COMFYUI_INPUT_DIR', '/home/batkhuu/ComfyUI/input'),
        storage_path('app/comfyui/input'),
        public_path('comfyui_input'),
        sys_get_temp_dir() . '/comfyui_input',
        '/tmp/comfyui_input'
    ];
    
    $saved = false;
    foreach ($inputDirs as $inputDir) {
        if (!file_exists($inputDir)) {
            mkdir($inputDir, 0777, true);
        }
        
        $fullPath = $inputDir . '/' . $filename;
        if (file_put_contents($fullPath, $imageData) !== false) {
            Log::info('Image saved successfully', ['path' => $fullPath]);
            $saved = true;
            break;
        }
    }
    
    if (!$saved) {
        throw new \Exception('Failed to save control image - no writable directory found');
    }
    
    // Get ControlNet model
    $controlnetModel = $this->getControlNetModel($preprocessor);
    
    // Prepare preprocessor-specific parameters
    $preprocessorParams = [];
    if ($preprocessor === 'canny') {
        $preprocessorParams = [
            'low_threshold' => $params['controlnet']['canny_low_normalized'] ?? 0.196,
            'high_threshold' => $params['controlnet']['canny_high_normalized'] ?? 0.588
        ];
        Log::info('Using Canny thresholds (normalized)', $preprocessorParams);
    }
    
    // Build workflow
    $workflow = [
        "4" => [
            "class_type" => "CheckpointLoaderSimple",
            "inputs" => ["ckpt_name" => $params['model']]
        ],
        "10" => [
            "class_type" => "LoadImage",
            "inputs" => ["image" => $filename]
        ],
        "11" => $this->getPreprocessorNode($preprocessor, "10", $preprocessorParams),
        "12" => [
            "class_type" => "ControlNetLoader",
            "inputs" => ["control_net_name" => $controlnetModel]
        ],
        "5" => [
            "class_type" => "EmptyLatentImage",
            "inputs" => [
                "width" => (int)($params['width'] ?? 512),
                "height" => (int)($params['height'] ?? 512),
                "batch_size" => 1
            ]
        ],
        "6" => [
            "class_type" => "CLIPTextEncode",
            "inputs" => [
                "text" => $params['positive_prompt'],
                "clip" => ["4", 1]
            ]
        ],
        "7" => [
            "class_type" => "CLIPTextEncode",
            "inputs" => [
                "text" => $params['negative_prompt'] ?? "",
                "clip" => ["4", 1]
            ]
        ],
        "13" => [
            "class_type" => "ControlNetApplyAdvanced",
            "inputs" => [
                "positive" => ["6", 0],
                "negative" => ["7", 0],
                "control_net" => ["12", 0],
                "image" => ["11", 0],
                "strength" => (float)$strength,
                "start_percent" => (float)$startPercent,
                "end_percent" => (float)$endPercent
            ]
        ],
        "3" => [
            "class_type" => "KSampler",
            "inputs" => [
                "seed" => rand(1, 999999999),
                "steps" => (int)($params['steps'] ?? 20),
                "cfg" => (float)($params['cfg'] ?? 7.5),
                "sampler_name" => $params['sampler'] ?? 'euler',
                "scheduler" => "normal",
                "denoise" => 1,
                "model" => ["4", 0],
                "positive" => ["13", 0],
                "negative" => ["13", 1],
                "latent_image" => ["5", 0]
            ]
        ],
        "8" => [
            "class_type" => "VAEDecode",
            "inputs" => [
                "samples" => ["3", 0],
                "vae" => ["4", 2]
            ]
        ],
        "9" => [
            "class_type" => "SaveImage",
            "inputs" => [
                "filename_prefix" => "controlnet_" . $preprocessor,
                "images" => ["8", 0]
            ]
        ]
    ];
    
    Log::info('ControlNet workflow built successfully', [
        'nodes' => array_keys($workflow),
        'controlnet_model' => $controlnetModel,
        'preprocessor_params' => $preprocessorParams
    ]);
    
    return $workflow;
}

    protected function getPreprocessorNode($preprocessor, $imageNode, $cannyParams = [])
    {
        $preprocessorMap = [
            'canny' => [
                "class_type" => "Canny",
                "inputs" => [
                    "image" => [$imageNode, 0],
                    "low_threshold" => $cannyParams['low_threshold'] ?? 0.196,
                    "high_threshold" => $cannyParams['high_threshold'] ?? 0.588
                ]
            ],
            'depth' => [
                "class_type" => "DepthAnythingPreprocessor",
                "inputs" => [
                    "image" => [$imageNode, 0],
                    "resolution" => 512
                ]
            ],
            'openpose' => [
                "class_type" => "OpenposePreprocessor",
                "inputs" => [
                    "image" => [$imageNode, 0],
                    "detect_hand" => "enable",
                    "detect_body" => "enable",
                    "detect_face" => "disable"
                ]
            ],
            'scribble' => [
                "class_type" => "ScribblePreprocessor",
                "inputs" => [
                    "image" => [$imageNode, 0],
                    "resolution" => 512
                ]
            ],
            'mlsd' => [
                "class_type" => "M-LSDPreprocessor",
                "inputs" => [
                    "image" => [$imageNode, 0],
                    "score_threshold" => 0.1,
                    "dist_threshold" => 0.1,
                    "resolution" => 512
                ]
            ],
            'hed' => [
                "class_type" => "HEDPreprocessor",
                "inputs" => [
                    "image" => [$imageNode, 0],
                    "safe" => "enable",
                    "resolution" => 512
                ]
            ],
            'seg' => [
                "class_type" => "SegformerPreprocessor",
                "inputs" => [
                    "image" => [$imageNode, 0],
                    "resolution" => 512
                ]
            ],
            'normal' => [
                "class_type" => "NormalMapPreprocessor",
                "inputs" => [
                    "image" => [$imageNode, 0],
                    "resolution" => 512
                ]
            ]
        ];
        
        if (!isset($preprocessorMap[$preprocessor])) {
            Log::warning("Preprocessor {$preprocessor} not found, falling back to canny");
            return $preprocessorMap['canny'];
        }
        
        return $preprocessorMap[$preprocessor];
    }

    protected function getControlNetModel($preprocessor)
    {
        $models = [
            'canny' => 'control_sd15_canny.pth',
            'depth' => 'control_sd15_depth.pth',
            'openpose' => 'control_sd15_openpose.pth',
            'scribble' => 'control_sd15_scribble.pth',
            'mlsd' => 'control_sd15_mlsd.pth',
            'hed' => 'control_sd15_hed.pth',
            'seg' => 'control_sd15_seg.pth',
            'normal' => 'control_sd15_normal.pth'
        ];
        
        return $models[$preprocessor] ?? 'control_sd15_canny.pth';
    }

