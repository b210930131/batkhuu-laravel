    public function health() {
    try {
        $response = Http::timeout(3)->get($this->comfyUrl . "/system_stats");
        if ($response->successful()) {
            $data = $response->json();
            $gpu = $data['devices'][0];
            
            return response()->json([
                'success' => true,
                'status' => 'online',
                'gpu_name' => $gpu['name'],
                'vram_total' => $gpu['vram_total'],
                'vram_free' => $gpu['vram_free'],
            ]);
        }
    } catch (\Exception $e) {
        return response()->json(['success' => false, 'error' => $e->getMessage()], 500);
    }
}

    public function debugModels()
    {
        try {
            $response = Http::timeout(10)->get($this->comfyUrl . '/object_info');
            if ($response->successful()) {
                $nodes = $response->json();
                $modelNodes = array_filter(array_keys($nodes), function($key) {
                    return strpos($key, 'Checkpoint') !== false ||
                           strpos($key, 'Model') !== false;
                });
                return response()->json(['models' => array_values($modelNodes)]);
            }
            return response()->json(['error' => 'Failed to fetch models'], 500);
        } catch (\Exception $e) {
            return response()->json(['error' => $e->getMessage()], 500);
        }
    }

