    public function proxyObjectInfo(Request $request)
{
    try {
        $response = Http::timeout(10)->get($this->comfyUrl . '/object_info');
        if ($response->failed()) return response()->json(['error' => 'Offline'], 500);

        $data = $response->json();
        
        // Extract Checkpoints
        $checkpoints = $data['CheckpointLoaderSimple']['input']['required']['ckpt_name'][0] ?? [];
        
        // Extract ControlNets
        $controlnets = $data['ControlNetLoader']['input']['required']['control_net_name'][0] ?? [];

        return response()->json([
            'checkpoints' => $checkpoints,
            'controlnets' => $controlnets,
            'raw' => $data // Keep for debugging
        ]);
    } catch (\Exception $e) {
        return response()->json(['error' => $e->getMessage()], 500);
    }
}

